{
  "name": "smarttv-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:tizen": "VITE_PLATFORM=tizen vite build --outDir dist/tizen",
    "build:webos": "VITE_PLATFORM=webos vite build --outDir dist/webos",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "hls.js": "^1.6.15",
    "preact": "^10.27.2",
    "preact-router": "^4.1.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.2",
    "terser": "^5.46.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1"
  }
}
